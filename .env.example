# Copy this file to .env and fill in values before deploying.
# Vite exposes only variables prefixed with VITE_ to the browser.

# Base URL for the API (leave empty to use the mock api.js)
VITE_API_BASE_URL=

# App display name (overrides default if set)
VITE_APP_TITLE=DUE Student Guide

# Set to "true" to enable verbose console logging in development
VITE_DEBUG=false
